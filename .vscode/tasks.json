{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "unit tests",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe",
      "args": [
        "-m",
        "pytest",
        "tests\\unit",
        "-q",
        "-p",
        "no:cacheprovider"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "integration smoke",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe",
      "args": [
        "-m",
        "pytest",
        "tests\\integration\\test_run_pipeline_smoke.py",
        "-q",
        "-p",
        "no:cacheprovider"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "run demo_fitness",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe",
      "args": [
        "run_pipeline.py",
        "--config",
        "configs\\demo_fitness.yaml"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "run demo_minecraft",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe",
      "args": [
        "run_pipeline.py",
        "--config",
        "configs\\demo_minecraft.yaml"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}