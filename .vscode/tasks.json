{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "open launcher",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "Start-Process .\\ui\\project_launcher.html"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "unit tests",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe",
      "args": [
        "-m",
        "pytest",
        "tests\\unit",
        "-q",
        "-p",
        "no:cacheprovider"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "integration smoke",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe",
      "args": [
        "-m",
        "pytest",
        "tests\\integration\\test_run_pipeline_smoke.py",
        "-q",
        "-p",
        "no:cacheprovider"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "run demo_fitness",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe",
      "args": [
        "run_pipeline.py",
        "--config",
        "configs\\demo_fitness.yaml"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "run demo_fitness and open dashboard",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe",
      "args": [
        "run_pipeline.py",
        "--config",
        "configs\\demo_fitness.yaml",
        "--open-dashboard"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "run demo_minecraft",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe",
      "args": [
        "run_pipeline.py",
        "--config",
        "configs\\demo_minecraft.yaml"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "run demo_minecraft and open dashboard",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe",
      "args": [
        "run_pipeline.py",
        "--config",
        "configs\\demo_minecraft.yaml",
        "--open-dashboard"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "open dashboard",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "Start-Process .\\reports\\run_dashboard.html"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "open runtime settings",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "Start-Process .\\reports\\runtime_settings.html"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "open source approval workspace",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "Start-Process .\\reports\\source_approval_workspace.html"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "open review workspace",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "Start-Process .\\reports\\review_workspace.html"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}

